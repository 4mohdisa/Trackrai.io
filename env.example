# -----------------------------------------------------------------------
# Analytics — scripts only load when these values are set
# -----------------------------------------------------------------------

# Google Analytics 4 — your GA4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity — your Clarity project ID (10-character alphanumeric, e.g. vy6p1f31tq)
# Get from: clarity.microsoft.com > your project > Settings > Overview
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# PostHog — project API key (e.g. phc_XXXXXXXXXXX)
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog — data region host (https://us.i.posthog.com or https://eu.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------
# Marketing pixels — each pixel only loads if its env var is set
# -----------------------------------------------------------------------

# Meta (Facebook) Pixel ID (e.g. 123456789012345)
# Tracks PageView automatically; fires Lead on CTA clicks
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel ID (e.g. ABCDEFGHIJ)
# Tracks page() automatically; fires ClickButton on CTA clicks
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Twitter / X Pixel ID (e.g. tw-xxxxx-xxxxx)
# Tracks page views and conversion events
NEXT_PUBLIC_TWITTER_PIXEL_ID=

# -----------------------------------------------------------------------
# Email / Resend  (required for the /help contact and feature-request forms)
# -----------------------------------------------------------------------

# Your Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address used for outgoing emails.
# Must be a verified domain/address in your Resend account.
EMAIL_FROM=

# Inbox that receives support / contact form submissions
SUPPORT_EMAIL_TO=

# Inbox that receives feature-request submissions (can be the same as above)
FEATURE_REQUEST_EMAIL_TO=
