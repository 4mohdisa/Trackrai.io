# -----------------------------------------------------------------------
# Analytics (optional — scripts are injected only when these are set)
# -----------------------------------------------------------------------

# Google Analytics — your GA4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Microsoft Clarity — your Clarity project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Meta (Facebook) Pixel — your Pixel ID (e.g. 123456789012345)
# Tracks PageView automatically; fires Lead event on sign-up CTA clicks
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel — your Pixel ID (e.g. ABCDEFGHIJ)
# Tracks page() automatically; fires ClickButton on sign-up CTA clicks
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# -----------------------------------------------------------------------
# Email / Resend  (required for the /help contact and feature-request forms)
# -----------------------------------------------------------------------

# Your Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address used for outgoing emails.
# Must be a verified domain/address in your Resend account.
# Example: Zepto <noreply@zeptoai.app>
EMAIL_FROM=Zepto <noreply@zeptoai.app>

# Inbox that receives support / contact form submissions
SUPPORT_EMAIL_TO=support@zeptoai.app

# Inbox that receives feature-request submissions (can be the same as above)
FEATURE_REQUEST_EMAIL_TO=support@zeptoai.app
